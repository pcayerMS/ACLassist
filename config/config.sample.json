{
  "target": {
    "tenantId": "<your-entra-tenant-id-or-domain>",
    "subscriptionId": "<your-subscription-id>",
    "resourceGroupName": "",
    "storageAccountName": "<your-adls-gen2-account>",
    "fileSystem": "<your-container>",
    "rootPath": "/"
  },
  "auth": {
    "loginHint": "",
    "graphScopes": [
      "Directory.Read.All",
      "Group.Read.All",
      "GroupMember.Read.All",
      "User.Read.All"
    ]
  },
  "groups": {
    "namePrefixes": [],
    "expandTransitiveMembership": true
  },
  "scan": {
    "includeAccessAces": true,
    "includeDefaultAces": true,
    "includeRbacAssignments": true,
    "maxConcurrency": 16,
    "retry": { "maxAttempts": 6, "baseDelayMs": 500 },
    "checkpointPath": "./data/.checkpoint.json",
    "pathFilters": { "includePrefixes": [], "excludePrefixes": [] }
  },
  "output": {
    "format": "both",
    "inventoryPath": "./data/inventory.json",
    "inventoryJsonlPath": "./data/inventory.jsonl"
  }
}
