{
  "name": "aclassist-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Portable, offline dashboard for the ADLS ACL -> RBAC assessment (reads data/inventory.json).",
  "scripts": {
    "generate-sample": "node scripts/generate-sample.mjs",
    "sync-data": "node scripts/copy-inventory.mjs",
    "build-proposal": "node scripts/build-proposal-xlsx.mjs",
    "predev": "node scripts/copy-inventory.mjs",
    "dev": "vite",
    "prebuild": "node scripts/copy-inventory.mjs",
    "build": "tsc --noEmit && vite build",
    "portable": "npm run build && node scripts/emit-portable.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@types/sql.js": "^1.4.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.14.1",
    "write-excel-file": "^4.1.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.7",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
